	gui.set_enabled(gui.get_node("challenge_popup"), false)
	gui.set_enabled(gui.get_node("challenge_title"), false)
	gui.set_enabled(gui.get_node("challenge_desc"), false)
	gui.set_enabled(gui.get_node("close_button"), false)
	gui.set_enabled(gui.get_node("close_bttn_txt"), false)

	gui.set_enabled(gui.get_node("answer_box"), false)
	gui.set_enabled(gui.get_node("answer_txt"), false)
	gui.set_enabled(gui.get_node("submit_bttn"), false)
	gui.set_enabled(gui.get_node("submit_txt"), false)
	gui.set_enabled(gui.get_node("challenge_result"), false)
	gui.set_enabled(gui.get_node("hint_bttn"), false)
	gui.set_enabled(gui.get_node("hint_txt"), false)
end

function update(self, dt)
	if self.challenge_active and self.timer_running then
		self.challenge_timer = self.challenge_timer + dt

		if self.challenge_timer >= self.next_penalty_time then
			self.score = self.score - self.time_penalty
			self.next_penalty_time = self.next_penalty_time + self.penalty_interval

			msg.post("/hud#hud", "update_score", { score = self.score })
			save_progress(self, 0)

			gui.set_text(gui.get_node("challenge_result"), "Time penalty: -" .. self.time_penalty .. " points")		end
	end
end

function answer_check(self)
	local url = SUPABASE_URL .. "/functions/v1/answer_check"

	local body = json.encode({
		challenge_id = self.current_challenge_id,
		answer = self.answer
	})
	local auth_token = session.access_token or SUPABASE_ANON_KEY
	
	local headers = {
		["apikey"] = SUPABASE_ANON_KEY,
		["Authorization"] = "Bearer " .. auth_token,
		["Content-Type"] = "application/json"
	}

	http.request(url, "POST", function(self, id, response)
		if response.status == 200 then
			local data = json.decode(response.response)

			if data.correct then
				self.timer_running = false

				if not self.completed_challenges[self.current_challenge_id] then
					local points = data.points or 100

					self.score = self.score + points
					self.completed_challenges[self.current_challenge_id] = true

					msg.post("/hud#hud", "update_score", { score = self.score })

					save_progress(self, points)
					
					gui.set_text(gui.get_node("challenge_result"), "Correct! +" .. points .. " points")
				else
					gui.set_text(gui.get_node("challenge_result"), "Already completed. Score: " .. self.score)
				end
			else
				self.lives = self.lives - 1
				msg.post("/hud#hud", "update_lives", { lives = self.lives })

				if self.lives <= 0 then
					mission_failed(self)
				else
					gui.set_text(gui.get_node("challenge_result"), "Incorrect! Lives left: " .. self.lives)
				end
			end
		else
			gui.set_text(gui.get_node("challenge_result"), "Answer check failed.")
			print("Function error:", response.status, response.response)
		end
	end, headers, body)
end

function mission_failed(self)
	self.score = 0
	self.lives = 3
	self.completed_challenges = {}
	self.timer_running = false
	reset_progress(self)

	msg.post("/hud#hud", "update_score", { score = self.score })
	msg.post("/hud#hud", "update_lives", { lives = self.lives })

	gui.set_text(gui.get_node("challenge_title"), "Mission Failed")
	gui.set_text(gui.get_node("challenge_desc"), "You got 3 answers wrong.\nReturning to start...")
	gui.set_text(gui.get_node("challenge_result"), "")

	msg.post("/player#player", "reset_player", {
		position = vmath.vector3(40, 87, -1)
	})

	timer.delay(2, false, function()
		hide_challenge(self)
	end)
end
function save_progress(self, points)
	if session.is_guest or not session.access_token then
		print("Guest mode: progress not saved")
		return
	end

	local headers = {
		["apikey"] = SUPABASE_ANON_KEY,
		["Authorization"] = "Bearer " .. session.access_token,
		["Content-Type"] = "application/json",
		["Prefer"] = "resolution=merge-duplicates"
	}

	local progress_body = json.encode({
		user_id = session.user_id,
		challenge_id = self.current_challenge_id,
		completed = true,
		score_awarded = points,
		completed_at = os.date("!%Y-%m-%dT%H:%M:%SZ")
	})

	http.request(SUPABASE_URL .. "/rest/v1/player_progress", "POST", function(_, _, response)
		print("SAVE PROGRESS:", response.status, response.response or "")
	end, headers, progress_body)

	local state_body = json.encode({
		user_id = session.user_id,
		score = self.score,
		lives = self.lives,
		updated_at = os.date("!%Y-%m-%dT%H:%M:%SZ")
	})

	http.request(SUPABASE_URL .. "/rest/v1/player_state", "POST", function(_, _, response)
		print("SAVE STATE:", response.status, response.response or "")
	end, headers, state_body)
end

function load_progress(self)
	if session.is_guest or not session.access_token then
		print("Guest mode: progress not loaded")
		return
	end

	local headers = {
		["apikey"] = SUPABASE_ANON_KEY,
		["Authorization"] = "Bearer " .. session.access_token
	}

	local state_url = SUPABASE_URL .. "/rest/v1/player_state?user_id=eq." .. session.user_id .. "&select=*"

	http.request(state_url, "GET", function(self, _, response)
		print("LOAD STATE:", response.status, response.response or "")

		if response.status == 200 then
			local data = json.decode(response.response)
			local state = data[1]

			if state then
				self.score = state.score or 0
				self.lives = state.lives or 3

				msg.post("/hud#hud", "update_score", { score = self.score })
				msg.post("/hud#hud", "update_lives", { lives = self.lives })
			end
		end
	end, headers)

	local progress_url = SUPABASE_URL .. "/rest/v1/player_progress?user_id=eq." .. session.user_id .. "&completed=eq.true&select=challenge_id"

	http.request(progress_url, "GET", function(self, _, response)
		print("LOAD PROGRESS:", response.status, response.response or "")

		if response.status == 200 then
			local data = json.decode(response.response)

			self.completed_challenges = {}

			for _, row in ipairs(data) do
				self.completed_challenges[row.challenge_id] = true
			end
		end
	end, headers)
end
function reset_progress(self)
	if session.is_guest or not session.access_token then
		print("Guest mode: reset locally only")
		return
	end

	local headers = {
		["apikey"] = SUPABASE_ANON_KEY,
		["Authorization"] = "Bearer " .. session.access_token,
		["Content-Type"] = "application/json",
		["Prefer"] = "resolution=merge-duplicates"
	}

	local state_body = json.encode({
		user_id = session.user_id,
		score = 0,
		lives = 3,
		updated_at = os.date("!%Y-%m-%dT%H:%M:%SZ")
	})

	http.request(SUPABASE_URL .. "/rest/v1/player_state", "POST",
	function(_, _, response)
		print("RESET STATE:", response.status)
	end,
	headers, state_body)

	local progress_body = json.encode({
		completed = false
	})

	local progress_url = SUPABASE_URL ..
	"/rest/v1/player_progress?user_id=eq." .. session.user_id

	http.request(progress_url, "PATCH",
	function(_, _, response)
		print("RESET PROGRESS:", response.status)
	end,
	headers, progress_body)
end