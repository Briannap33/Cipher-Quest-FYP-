end

function on_message(self, message_id, message, sender)
	if message_id == hash("show_interact_prompt") then
		gui.set_enabled(gui.get_node("interaction_prompt"), true)
		return
	end

	if message_id == hash("hide_interact_prompt") then
		gui.set_enabled(gui.get_node("interaction_prompt"), false)
		return
	end

	if message_id == hash("start_dialogue") then
		self.dialogue_active = true
		self.challenge_active = false
		self.current_challenge_id = message.challenge_id
		self.answer = ""

		gui.set_text(gui.get_node("answer_txt"), "")
		gui.set_text(gui.get_node("challenge_result"), "")
		gui.set_text(gui.get_node("hint_txt"), "")
		gui.set_text(gui.get_node("challenge_title"), "")
		gui.set_text(gui.get_node("challenge_desc"), "")

		gui.set_enabled(gui.get_node("challenge_popup"), false)

		gui.set_enabled(gui.get_node("interaction_prompt"), false)
		gui.set_enabled(gui.get_node("NPC_dialogue"), true)
		gui.set_enabled(gui.get_node("NPC_dialogue_txt"), true)
		gui.set_enabled(gui.get_node("continue_txt"), true)

		gui.set_text(gui.get_node("NPC_dialogue_txt"), message.text)
		return
	end
end


function on_input(self, action_id, action)

	if action_id == hash("touch") and action.pressed then
		local x = action.x
		local y = action.y

		if self.dialogue_active then
			local continue_node = gui.get_node("continue_txt")

			if gui.pick_node(continue_node, x, y) then
				show_challenge(self)
				return true
			end
		end

		if self.challenge_active then
			local close_node = gui.get_node("close_button")
			local submit_node = gui.get_node("submit_bttn")
			local hint_node = gui.get_node("hint_bttn")

			if gui.pick_node(submit_node, x, y) then
				answer_check(self)
				return true
			end

			if gui.pick_node(hint_node, x, y) then
				if self.current_challenge and self.current_challenge.hint then
					gui.set_text(gui.get_node("hint_txt"), self.current_challenge.hint)
				end
				return true
			end

			if gui.pick_node(close_node, x, y) then
				hide_challenge(self)
				return true
			end
		end
	end

	if self.challenge_active and action_id == hash("backspace") and action.pressed then
		self.answer = string.sub(self.answer, 1, #self.answer - 1)
		gui.set_text(gui.get_node("answer_txt"), self.answer)
		return true
	end

	if self.challenge_active and action_id == hash("text") then
		print("typed:", action.text)

		if action.text then
			self.answer = self.answer .. action.text
			gui.set_text(gui.get_node("answer_txt"), self.answer)
		end

		return true
	end
end

function fetch_challenge(self, challenge_id)
	local url = SUPABASE_URL .. "/rest/v1/challenges?id=eq." .. challenge_id .. "&select=id,title,description,hint,points,time_penalty,penalty_interval,max_attempts"

	local headers = {
		["apikey"] = SUPABASE_ANON_KEY,
		["Authorization"] = "Bearer " .. SUPABASE_ANON_KEY
		}

	http.request(url, "GET", function(self, id, response)
		if response.status == 200 then
			local data = json.decode(response.response)
			local challenge = data[1]

			if challenge then
				self.current_challenge = challenge

				self.penalty_interval = challenge.penalty_interval or 90
				self.time_penalty = challenge.time_penalty or 10
				self.lives = challenge.max_attempts or 3

				self.challenge_timer = 0
				self.next_penalty_time = self.penalty_interval
				self.timer_running = true

				msg.post("/hud#hud", "update_lives", { lives = self.lives })

				gui.set_text(gui.get_node("challenge_title"), challenge.title)
				gui.set_text(gui.get_node("challenge_desc"), challenge.description)
			end
		end
	end, headers)
end

