	gui.set_enabled(gui.get_node("submit_txt"), true)
	gui.set_enabled(gui.get_node("challenge_result"), true)
	gui.set_enabled(gui.get_node("hint_bttn"), true)
	gui.set_enabled(gui.get_node("hint_txt"), true)
	gui.set_enabled(gui.get_node("challenge_popup"), true)
	gui.set_enabled(gui.get_node("challenge_title"), true)
	gui.set_enabled(gui.get_node("challenge_desc"), true)
	gui.set_enabled(gui.get_node("close_button"), true)
	gui.set_enabled(gui.get_node("close_bttn_txt"), true)
	
	gui.set_text(gui.get_node("answer_txt"), "")
	gui.set_text(gui.get_node("challenge_result"), "")
	gui.set_text(gui.get_node("hint_txt"), "")
	gui.set_text(gui.get_node("challenge_title"), "Loading...")
	gui.set_text(gui.get_node("challenge_desc"), "")

	fetch_challenge(self, self.current_challenge_id)
	
end

